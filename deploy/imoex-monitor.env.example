# Скопировать в /etc/imoex-monitor.env и заполнить значения.
# chmod 600 /etc/imoex-monitor.env

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=

# Куда слать алерты. Для канала:
#   - либо @channelname (если канал публичный),
#   - либо -100xxxxxxxxxx (числовой chat_id).
# Бот должен быть админом канала с правом постить.
TELEGRAM_CHAT_ID=

# HTTP-прокси для запросов к api.telegram.org (если прямой доступ закрыт).
# Применяется ТОЛЬКО к Telegram — MOEX-запросы идут напрямую.
# Пример: http://127.0.0.1:3128
TELEGRAM_PROXY=
